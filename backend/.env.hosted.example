# FretVision backend — HOSTED template.
# Values marked VERIFY_* are deployment-blocking placeholders: they intentionally
# fail startup until the corresponding unresolved item is verified against
# first-party Supabase docs and the actual project signing/connection config.
#   - U5: JWKS URL + expected issuer/audience for the real signing configuration
#   - U6: hosted connection mode (Supavisor session mode vs direct connection)

# ----- Application ----------------------------------------------------------
APP_ENV=production
LOG_LEVEL=INFO

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# ----- Database -------------------------------------------------------------
DATABASE_URL=REPLACE_AFTER_HOSTED_DATABASE_ROLE_IS_CONFIGURED
# U6 unresolved: choose `direct` or `session` (NOT transaction pooling) once the
# host's supported connection mode is verified. Placeholder blocks startup.
DB_CONNECTION_MODE=VERIFY_U6_direct_or_session
DB_APPLICATION_NAME=fretvision-backend
DB_POOL_MIN_SIZE=0
DB_POOL_MAX_SIZE=10
DB_COMMAND_TIMEOUT=30
DB_CONNECT_TIMEOUT=10

# ----- JWT verification (JWKS is the required hosted/production mode) --------
JWT_VERIFICATION_MODE=jwks
SUPABASE_JWKS_URL=https://YOUR_PROJECT_REF.supabase.co/auth/v1/.well-known/jwks.json
# U5 unresolved: set to the real issuer/audience from the project signing config.
JWT_ISSUER=VERIFY_U5_ISSUER
JWT_AUDIENCE=VERIFY_U5_AUDIENCE
# Comma-separated asymmetric algorithms only. HS256 is rejected.
JWT_ALLOWED_ALGORITHMS=ES256
JWKS_CACHE_TTL_SECONDS=300
JWKS_HTTP_TIMEOUT=5

# ----- Optional -------------------------------------------------------------
# Only when FastAPI separately calls privileged Supabase HTTP APIs.
# SUPABASE_SECRET_KEY=sb_secret_REPLACE_ME
