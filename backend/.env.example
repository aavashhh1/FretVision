# FretVision backend — LOCAL development template.
# Copy to backend/.env and fill in local values. Never commit backend/.env.

# ----- Application ----------------------------------------------------------
APP_ENV=local
LOG_LEVEL=INFO

# ----- Database (connects as the least-privilege backend role) --------------
# Direct connection to the local Supabase Postgres container.
DATABASE_URL=postgresql://fretvision_app:REPLACE_LOCAL_PASSWORD@127.0.0.1:54322/postgres
# Ratified connection modes only: direct | session. Never transaction pooling.
DB_CONNECTION_MODE=direct
DB_APPLICATION_NAME=fretvision-backend
# Lazy pool: min_size 0 means startup does not require the DB to be reachable.
DB_POOL_MIN_SIZE=0
DB_POOL_MAX_SIZE=10
DB_COMMAND_TIMEOUT=30
DB_CONNECT_TIMEOUT=10

# ----- JWT verification -----------------------------------------------------
# Local development uses the auth_server mode: bearer tokens are validated
# against the local Supabase Auth /auth/v1/user endpoint. FastAPI never holds
# the legacy HS256 secret and performs no local signature verification.
JWT_VERIFICATION_MODE=auth_server
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_PUBLISHABLE_KEY=REPLACE_LOCAL_PUBLISHABLE_KEY
# auth_server is a local-only compatibility path; production must not use it
# unless this guard is explicitly set to true.
ALLOW_AUTH_SERVER_IN_PROD=false

# ----- JWKS mode (hosted target; unused when JWT_VERIFICATION_MODE=auth_server)
# SUPABASE_JWKS_URL=http://127.0.0.1:54321/auth/v1/.well-known/jwks.json
# JWT_ISSUER=http://127.0.0.1:54321/auth/v1
# JWT_AUDIENCE=authenticated
# JWT_ALLOWED_ALGORITHMS=ES256
# JWKS_CACHE_TTL_SECONDS=300
# JWKS_HTTP_TIMEOUT=5

# ----- Integration tests ----------------------------------------------------
# Required only for `uv run pytest -m integration`. Never reuse DATABASE_URL.
# TEST_DATABASE_URL=postgresql://fretvision_app:REPLACE_LOCAL_PASSWORD@127.0.0.1:54322/postgres
